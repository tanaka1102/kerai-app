# NextAuth.js
AUTH_SECRET=your-auth-secret-here  # openssl rand -base64 32 で生成
NEXTAUTH_SECRET=your-auth-secret-here  # AUTH_SECRETと同じ値を設定

# Google OAuth（GCPのWebアプリ認証情報）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth URL
NEXTAUTH_URL=https://kerai-app.vercel.app

# Resend（メール送信）
# https://resend.com で無料アカウント作成 → API Keys からキー取得
# 無料枠: 3,000通/月、100通/日
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Upstash Redis（rate limiting）
# https://console.upstash.com でRedisDB作成 → REST API から取得
# 無料枠: 10,000コマンド/日
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
