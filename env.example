# NextAuth.js
AUTH_SECRET=your-auth-secret-here  # openssl rand -base64 32 で生成
NEXTAUTH_SECRET=your-auth-secret-here  # AUTH_SECRETと同じ値を設定

# Google OAuth（GCPのWebアプリ認証情報）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth URL
NEXTAUTH_URL=https://kerai-app.vercel.app
